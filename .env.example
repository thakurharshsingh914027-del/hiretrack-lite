# Copy this file to .env.local for development. Prisma commands load
# .env.local first, then .env, while preserving values already set by the shell.
# Every value below is a non-secret placeholder. Never commit populated env files.

# PostgreSQL (required for migrations, seeding, integration tests, and data routes)
# DATABASE_URL may be pooled for the application. DIRECT_URL must be a direct
# connection for migration commands. Use isolated databases per environment.
DATABASE_URL="postgresql://hiretrack:hiretrack@localhost:5432/hiretrack_lite?schema=public"
DIRECT_URL="postgresql://hiretrack:hiretrack@localhost:5432/hiretrack_lite?schema=public"

# Auth.js (introduced with the authentication milestone)
# Generate a unique high-entropy value for each deployed environment, for
# example with: openssl rand -base64 32. Placeholders are rejected in production.
AUTH_SECRET="replace-with-a-unique-secret-of-at-least-32-bytes"
AUTH_URL="http://localhost:3000"

# OAuth callback URLs (when enabled):
# Google/GitHub: https://your-host.example.com/api/auth/{provider}/callback

# Optional OAuth providers. Leave both values in a provider pair empty to disable it.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Browser-safe canonical links; these variables must never contain credentials.
# Set NEXT_PUBLIC_APP_URL in production. Vercel deployments can derive it from
# the platform-provided VERCEL_PROJECT_PRODUCTION_URL when this value is absent.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_REPOSITORY_URL=""

# Transactional email through Resend (introduced with authentication)
RESEND_API_KEY="re_replace_with_a_resend_api_key"
EMAIL_FROM="noreply@example.com"

# Private resume storage through Vercel Blob (introduced with candidates)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_replace_with_a_private_token"

# Distributed rate limiting through Upstash Redis (introduced with authentication)
UPSTASH_REDIS_REST_URL="https://replace-with-your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-an-upstash-rest-token"

# Idempotent demo seed. Replace the password before running `npm run db:seed`;
# the documented placeholder is rejected and the value is hashed with Argon2id.
DEMO_ORGANIZATION_NAME="HireTrack Demo"
DEMO_ADMIN_NAME="Demo Admin"
DEMO_ADMIN_EMAIL="demo@example.com"
DEMO_ADMIN_PASSWORD="replace-with-a-local-demo-password"
