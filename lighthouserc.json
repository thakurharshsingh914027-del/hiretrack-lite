{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start -- --hostname 127.0.0.1 --port 3000",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/docs/features",
        "http://127.0.0.1:3000/faq",
        "http://127.0.0.1:3000/app"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "^http://127\\.0\\.0\\.1:3000/(?:$|docs|faq)",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.9 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo": ["error", { "minScore": 0.95 }]
          }
        },
        {
          "matchingUrlPattern": "^http://127\\.0\\.0\\.1:3000/app",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.9 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }]
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
